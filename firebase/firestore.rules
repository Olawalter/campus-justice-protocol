rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('ADMIN');
    }

    function isInstitution() {
      return hasRole('INSTITUTION');
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Cases collection (metadata cache only — source of truth is GenLayer)
    match /cases/{caseId} {
      allow read: if isAuthenticated() && (
        // Student who filed the case
        resource.data.filerUid == request.auth.uid ||
        // Institution — matched by institutionId stored on their profile
        (isInstitution() && resource.data.institutionAddress == getUserData().institutionId) ||
        // Admin can read all
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.filerUid == request.auth.uid ||
        (isInstitution() && resource.data.institutionAddress == getUserData().institutionId) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Institutions collection
    match /institutions/{institutionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow update: if isAuthenticated() && (isOwner(institutionId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.recipientUid == request.auth.uid;
    }

    // Precedents cache (public read)
    match /precedents/{precedentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
