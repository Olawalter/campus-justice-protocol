rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Evidence files: owner upload, case parties read
    match /evidence/{userId}/{caseId}/{fileName} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        // Institution and admin access checked via Firestore case document
        true
      );
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 && // 10MB max
        request.resource.contentType.matches('application/pdf|image/.*|application/msword|application/vnd.openxmlformats.*');
    }

    // Institution response files
    match /responses/{institutionId}/{caseId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == institutionId &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('application/pdf|image/.*|application/msword|application/vnd.openxmlformats.*');
    }

    // Profile images
    match /profiles/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 2 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
